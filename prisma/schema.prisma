generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model HR {
  id                 String         @id @default(cuid())
  name               String
  email              String         @unique
  password           String
  organization       String
  organizationDomain String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  phone              String?
  departments        Department[]
  holidays           Holiday[]
  leaveRequests      LeaveRequest[]
  sentMessages       Message[]      @relation("HRSender")
  tasks              Task[]
}

model Department {
  id         String     @id @default(cuid())
  name       String
  hrId       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  budget     String?
  capacity   Int?
  efficiency Int?
  managerId  String?
  hr         HR         @relation(fields: [hrId], references: [id])
  manager    Employee?  @relation("ManagerIntern", fields: [managerId], references: [id])
  employees  Employee[] @relation("DepartmentStaff")
  messages   Message[]  @relation("SiloMessages")
  projects   Project[]  @relation("DepartmentProjects")
  tasks      Task[]     @relation("DepartmentTasks")
}

model Employee {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  role          String         @default("INTERN")
  departmentId  String?
  managerId     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  position      String?        @default("Workforce Member")
  hrId          String?
  attendances   Attendance[]
  manages       Department[]   @relation("ManagerIntern")
  department    Department?    @relation("DepartmentStaff", fields: [departmentId], references: [id])
  manager       Employee?      @relation("ManagerIntern", fields: [managerId], references: [id])
  subordinates  Employee[]     @relation("ManagerIntern")
  leaveRequests LeaveRequest[]
  sentMessages  Message[]      @relation("EmployeeSender")
  tasks         Task[]
}

model Attendance {
  id         String   @id @default(cuid())
  employeeId String
  timestamp  DateTime @default(now())
  photo      String?
  location   String?
  type       String
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Task {
  id           String      @id @default(cuid())
  title        String
  description  String?
  hrId         String?
  employeeId   String
  createdAt    DateTime    @default(now())
  departmentId String?
  status       String      @default("TODO")
  department   Department? @relation("DepartmentTasks", fields: [departmentId], references: [id])
  employee     Employee    @relation(fields: [employeeId], references: [id])
  hr           HR?         @relation(fields: [hrId], references: [id])
}

model Project {
  id           String     @id @default(cuid())
  name         String
  description  String
  status       String     @default("PLANNING")
  departmentId String
  createdAt    DateTime   @default(now()) @db.Timestamp(6)
  updatedAt    DateTime   @default(now()) @updatedAt @db.Timestamp(6)
  department   Department @relation("DepartmentProjects", fields: [departmentId], references: [id])
}

model Holiday {
  id    String   @id @default(cuid())
  date  DateTime
  title String
  hrId  String
  hr    HR       @relation(fields: [hrId], references: [id])
}

model LeaveRequest {
  id         String    @id @default(cuid())
  title      String
  startDate  DateTime
  endDate    DateTime
  employeeId String
  hrId       String?
  status     String    @default("PENDING")
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  reason     String?
  employee   Employee  @relation(fields: [employeeId], references: [id])
  hr         HR?       @relation(fields: [hrId], references: [id])
}

model Message {
  id               String      @id @default(cuid())
  content          String
  createdAt        DateTime    @default(now())
  departmentId     String?
  employeeSenderId String?
  hrSenderId       String?
  receiverId       String?
  department       Department? @relation("SiloMessages", fields: [departmentId], references: [id])
  employeeSender   Employee?   @relation("EmployeeSender", fields: [employeeSenderId], references: [id])
  hrSender         HR?         @relation("HRSender", fields: [hrSenderId], references: [id])
}

model Broadcast {
  id         String    @id(map: "broadcasts_pkey") @default(dbgenerated("nextval('broadcasts_id_seq'::regclass)")) @db.VarChar(36)
  senderId   String    @db.VarChar(36)
  senderRole String    @db.VarChar(20)
  message    String
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  visibility String    @db.VarChar(20)
  hrId       String?
}

model User {
  id          String    @id
  name        String
  email       String    @unique
  role        String
  original_id String?
  createdat   DateTime? @default(now()) @db.Timestamp(6)
}

enum RoleType {
  ADMIN
  MANAGER
  INTERN
}
