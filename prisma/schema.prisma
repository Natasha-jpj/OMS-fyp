generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model HR {
  id                 String         @id @default(cuid())
  name               String
  email              String         @unique
  password           String
  organization       String
  organizationDomain String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  phone              String?
  departments        Department[]
  holidays           Holiday[]
  leaveRequests      LeaveRequest[]
  sentMessages       Message[]      @relation("HRSender")
  tasks              Task[]
}

model Department {
  id         String     @id @default(cuid())
  name       String
  hrId       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  budget     String?
  capacity   Int?
  efficiency Int?
  managerId  String?
  hr         HR         @relation(fields: [hrId], references: [id])
  manager    Employee?  @relation("ManagerIntern", fields: [managerId], references: [id])
  employees  Employee[] @relation("DepartmentStaff")
  messages   Message[]  @relation("SiloMessages")
  projects   Project[]  @relation("DepartmentProjects")
  tasks      Task[]     @relation("DepartmentTasks")
}

model Employee {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  password          String
  role              String             @default("INTERN")
  departmentId      String?
  managerId         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  position          String?            @default("Workforce Member")
  hrId              String?
  phone             String?
  salary            Decimal?           @db.Decimal(10, 2)
  contractType      String?            @default("Full-time")
  contractEndDate   DateTime?          @db.Timestamp(6)
  employmentStatus  String?            @default("Active")
  contractUrl       String?
  attendances       Attendance[]
  contractDocuments ContractDocument[] @relation("UploadedContracts")
  uploadedContracts ContractDocument[] @relation("UploadedBy")
  manages           Department[]       @relation("ManagerIntern")
  department        Department?        @relation("DepartmentStaff", fields: [departmentId], references: [id])
  manager           Employee?          @relation("ManagerIntern", fields: [managerId], references: [id])
  subordinates      Employee[]         @relation("ManagerIntern")
  leaveRequests     LeaveRequest[]
  sentMessages      Message[]          @relation("EmployeeSender")
  tasks             Task[]
}

model Attendance {
  id         String   @id @default(cuid())
  employeeId String
  timestamp  DateTime @default(now())
  photo      String?
  location   String?
  type       String
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Task {
  id           String      @id @default(cuid())
  title        String
  description  String?
  hrId         String?
  employeeId   String
  createdAt    DateTime    @default(now())
  departmentId String?
  status       String      @default("TODO")
  department   Department? @relation("DepartmentTasks", fields: [departmentId], references: [id])
  employee     Employee    @relation(fields: [employeeId], references: [id])
  hr           HR?         @relation(fields: [hrId], references: [id])
}

model Project {
  id           String     @id @default(cuid())
  name         String
  description  String
  status       String     @default("PLANNING")
  departmentId String
  createdAt    DateTime   @default(now()) @db.Timestamp(6)
  updatedAt    DateTime   @default(now()) @updatedAt @db.Timestamp(6)
  department   Department @relation("DepartmentProjects", fields: [departmentId], references: [id])
}

model Holiday {
  id    String   @id @default(cuid())
  date  DateTime
  title String
  hrId  String
  hr    HR       @relation(fields: [hrId], references: [id])
}

model LeaveRequest {
  id         String    @id @default(cuid())
  title      String
  startDate  DateTime
  endDate    DateTime
  employeeId String
  hrId       String?
  status     String    @default("PENDING")
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  reason     String?
  employee   Employee  @relation(fields: [employeeId], references: [id])
  hr         HR?       @relation(fields: [hrId], references: [id])
}

model Message {
  id               String      @id @default(cuid())
  content          String
  createdAt        DateTime    @default(now())
  departmentId     String?
  employeeSenderId String?
  hrSenderId       String?
  receiverId       String?
  department       Department? @relation("SiloMessages", fields: [departmentId], references: [id])
  employeeSender   Employee?   @relation("EmployeeSender", fields: [employeeSenderId], references: [id])
  hrSender         HR?         @relation("HRSender", fields: [hrSenderId], references: [id])
}

model Broadcast {
  id         String    @id(map: "broadcasts_pkey") @default(dbgenerated("nextval('broadcasts_id_seq'::regclass)")) @db.VarChar(36)
  senderId   String    @db.VarChar(36)
  senderRole String    @db.VarChar(20)
  message    String
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  visibility String    @db.VarChar(20)
  hrId       String?
}

model User {
  id          String    @id
  name        String
  email       String    @unique
  role        String
  original_id String?
  createdat   DateTime? @default(now()) @db.Timestamp(6)
}

model ContractDocument {
  id         String    @id @default(dbgenerated("gen_random_uuid()"))
  employeeId String
  fileName   String
  fileUrl    String
  uploadedAt DateTime? @default(now()) @db.Timestamp(6)
  uploadedBy String
  employee   Employee  @relation("UploadedContracts", fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  uploader   Employee  @relation("UploadedBy", fields: [uploadedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([employeeId], map: "idx_contract_employee")
}

// ============================================
// PAYROLL SYSTEM MODELS
// ============================================

model PayrollConfiguration {
  id                  String   @id @default(cuid())
  organizationId      String
  ssfEmployeeRate     Float    @default(11) // 11%
  ssfEmployerRate     Float    @default(20) // 20%
  minimumWage         Decimal  @db.Decimal(15, 2) @default(13500)
  currency            String   @default("NPR")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?
  updatedBy           String?

  @@unique([organizationId])
}

model TaxSlab {
  id                  String   @id @default(cuid())
  organizationId      String
  minIncome           Decimal  @db.Decimal(15, 2)
  maxIncome           Decimal? @db.Decimal(15, 2)
  taxRate             Float    // Percentage (0-100)
  reliefAmount        Decimal  @db.Decimal(15, 2) @default(0)
  effectiveFromDate   DateTime
  effectiveToDate     DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?
  updatedBy           String?

  @@index([organizationId])
  @@index([effectiveFromDate])
}

model SalaryStructure {
  id                  String   @id @default(cuid())
  organizationId      String
  employeeId          String
  basicSalary         Decimal  @db.Decimal(15, 2)
  allowances          Json     // { "hra": 15000, "dearness": 10000, ... }
  effectiveFromDate   DateTime
  effectiveToDate     DateTime?
  department          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?
  updatedBy           String?

  @@index([organizationId])
  @@index([employeeId])
  @@index([effectiveFromDate])
}

model PayrollRun {
  id                  String   @id @default(cuid())
  organizationId      String
  month               Int      // 1-12
  year                Int
  status              String   @default("DRAFT") // DRAFT, CALCULATED, FINALIZED, PAID, CANCELLED
  locked              Boolean  @default(false)
  totalGrossSalary    Decimal  @db.Decimal(15, 2) @default(0)
  totalNetSalary      Decimal  @db.Decimal(15, 2) @default(0)
  totalSSFEmployee    Decimal  @db.Decimal(15, 2) @default(0)
  totalSSFEmployer    Decimal  @db.Decimal(15, 2) @default(0)
  totalTax            Decimal  @db.Decimal(15, 2) @default(0)
  notes               String?
  processedAt         DateTime?
  finalizedAt         DateTime?
  finalizedBy         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?
  updatedBy           String?

  records             PayrollRecord[]

  @@unique([organizationId, month, year])
  @@index([organizationId])
  @@index([status])
}

model PayrollRecord {
  id                  String   @id @default(cuid())
  organizationId      String
  payrollRunId        String
  employeeId          String
  employeeName        String
  position            String?
  department          String?
  basicSalary         Decimal  @db.Decimal(15, 2)
  allowances          Json     // Individual allowance breakdown
  grossSalary         Decimal  @db.Decimal(15, 2)
  ssfEmployee         Decimal  @db.Decimal(15, 2)
  ssfEmployer         Decimal  @db.Decimal(15, 2)
  taxableIncome       Decimal  @db.Decimal(15, 2)
  incomeTax           Decimal  @db.Decimal(15, 2)
  leaveDeduction      Decimal  @db.Decimal(15, 2) @default(0)
  manualDeductions    Decimal  @db.Decimal(15, 2) @default(0)
  totalDeductions     Decimal  @db.Decimal(15, 2)
  netSalary           Decimal  @db.Decimal(15, 2)
  status              String   @default("PENDING") // PENDING, CALCULATED, VERIFIED, PAID, CORRECTION
  bankAccount         String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?
  updatedBy           String?

  payrollRun          PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
  @@index([organizationId])
  @@index([payrollRunId])
  @@index([employeeId])
  @@index([status])
}

model LeaveDeduction {
  id                  String   @id @default(cuid())
  organizationId      String
  payrollRecordId     String
  employeeId          String
  leaveType           String   // Casual, Sick, Annual, Unpaid
  days                Decimal  @db.Decimal(5, 2)
  dailyRate           Decimal  @db.Decimal(15, 2)
  deductionAmount     Decimal  @db.Decimal(15, 2)
  approvalStatus      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy          String?
  approvalDate        DateTime?
  reason              String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([organizationId])
  @@index([payrollRecordId])
  @@index([employeeId])
}

model ManualDeduction {
  id                  String   @id @default(cuid())
  organizationId      String
  payrollRecordId     String
  employeeId          String
  description         String   // Loan repayment, penalty, etc.
  amount              Decimal  @db.Decimal(15, 2)
  deductionType       String   // LOAN, PENALTY, INSURANCE, OTHER
  approvalRequired    Boolean  @default(true)
  approvalStatus      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy          String?
  approvalDate        DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([organizationId])
  @@index([payrollRecordId])
  @@index([employeeId])
}

model PayrollAuditLog {
  id                  String   @id @default(cuid())
  organizationId      String
  entityType          String   // PayrollRun, PayrollRecord, TaxSlab, etc.
  entityId            String
  action              String   // CREATE, UPDATE, DELETE, FINALIZE, APPROVE
  changes             Json?    // { oldValues: {}, newValues: {} }
  reason              String?
  createdAt           DateTime @default(now())
  createdBy           String?

  @@index([organizationId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model PayslipTemplate {
  id                  String   @id @default(cuid())
  organizationId      String
  name                String
  templateHtml        String?  // HTML template for payslip
  emailTemplate       String?  // Email body template
  includeAllowances   Boolean  @default(true)
  includeDeductions   Boolean  @default(true)
  showBankDetails     Boolean  @default(true)
  showSSF             Boolean  @default(true)
  isDefault           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([organizationId])
}

enum RoleType {
  ADMIN
  MANAGER
  INTERN
}
